<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:elevation="6dp">

    <!-- 标题栏（可折叠/展开摇杆） -->
    <LinearLayout
        android:id="@+id/float_header"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@drawable/float_bg"
        android:padding="8dp"
        android:elevation="4dp">

        <TextView
            android:id="@+id/float_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📍 GPS"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:layout_gravity="center_vertical" />

        <TextView
            android:id="@+id/float_coords"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#FFFFFF"
            android:textSize="11sp"
            android:paddingStart="8dp"
            android:layout_gravity="center_vertical" />

    </LinearLayout>

    <!-- 摇杆区域（初始隐藏，模拟时展开） -->
    <FrameLayout
        android:id="@+id/joystick_container"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone"
        android:background="#DD1976D2"
        android:padding="6dp">

        <com.fakegps.app.ui.JoystickView
            android:id="@+id/joystick_view"
            android:layout_width="160dp"
            android:layout_height="160dp" />

    </FrameLayout>

</LinearLayout>
